# Farm Buddy production environment
# Copy this file on the Linux server:
#   cp .env.production.example .env.docker
#
# Replace every "CHANGE_ME" before starting production.

# ---------- PostgreSQL ----------
POSTGRES_DB=farmbuddy
POSTGRES_USER=farmbuddy
POSTGRES_PASSWORD=farmbuddy_password@KPW
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432

# If PostgreSQL is hosted outside Docker, set DATABASE_URL in the backend host
# instead of using the POSTGRES_* Docker values.
# DATABASE_URL=postgresql://farmbuddy:CHANGE_ME@postgres:5432/farmbuddy

# ---------- Flask backend ----------
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=8000
JWT_SECRET=CHANGE_ME_USE_64_PLUS_RANDOM_CHARACTERS
JWT_EXPIRES_HOURS=168
CORS_ORIGINS=https://farming-guide.com,https://www.farming-guide.com

# ---------- React frontend ----------
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=5173

# If Nginx/Cloudflare proxies /api to the backend on the same domain, use:
VITE_API_BASE_URL=https://farming-guide.com

# If backend is on a separate subdomain, use something like:
# VITE_API_BASE_URL=https://api.farming-guide.com

# Temporary placeholders while the old frontend screens are migrated away from
# Supabase. Do not put real secrets in VITE_ variables.
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=placeholder

# ---------- AI assistant ----------
# Backend-only secrets. Do not expose these in browser code.
AI_PROVIDER=gemini
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.3

# Optional OpenAI fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low

# ---------- Optional notifications ----------
TWILIO_API_KEY=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=
