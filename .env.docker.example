# Default Docker environment for local development.
# For production, copy `.env.production.example` to `.env.docker` instead.

POSTGRES_DB=farmbuddy_dev
POSTGRES_USER=farmbuddy
POSTGRES_PASSWORD=change_this_dev_database_password
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432

BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=8000
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=5173
JWT_SECRET=change_this_dev_jwt_secret_use_a_long_random_text
JWT_EXPIRES_HOURS=168
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=http://localhost:8000

# Keep AI keys on the backend only. Never prefix real AI keys with VITE_.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low

# Optional notifications.
TWILIO_API_KEY=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=

# Temporary placeholders so the current React app can start while pages are
# migrated from Supabase calls to the Flask API.
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=placeholder
