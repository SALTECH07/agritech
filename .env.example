SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_key

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

# AI assistant and farm advice. If both keys are present, Gemini is used first
# unless AI_PROVIDER is set to openai.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.3

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low

# Optional notification integrations
LOVABLE_API_KEY=
TWILIO_API_KEY=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=
